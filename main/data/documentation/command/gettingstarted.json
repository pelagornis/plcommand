{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Installation","level":2,"type":"heading","text":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"PLCommand was deployed as Swift Package Manager. Package to install in a project. Add as a dependent item within the swift manifest."}]},{"type":"codeListing","syntax":"swift","code":["let package = Package(","    ...","    dependencies: [","        .package(url: \"https:\/\/github.com\/pelagornis\/plcommand.git\", from: \"1.2.1\")","    ],","    ...",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then import the PLCommand from thr location you want to use."}]},{"type":"codeListing","syntax":"swift","code":["import Command"]},{"anchor":"Using-PLCommand","level":2,"type":"heading","text":"Using PLCommand"},{"type":"paragraph","inlineContent":[{"type":"text","text":"PLCommand offers the most commonly used "},{"type":"codeVoice","code":"bash"},{"type":"text","text":" and "},{"type":"codeVoice","code":"zsh"},{"type":"text","text":" and "},{"type":"codeVoice","code":"make"},{"type":"text","text":", which in addition helps users scale easily."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to use Bash."}]},{"type":"codeListing","syntax":"swift","code":["@Command(\\.bash) var bashCommand","bashCommand.run(\"command\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or if you want to use zsh."}]},{"type":"codeListing","syntax":"swift","code":["@Command(\\.zsh) var zshCommand","zshCommand.run(\"command\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or if you want to use Makefile command."}]},{"type":"codeListing","syntax":"swift","code":["@Command(\\.make) var makeCommand","makeCommand.run(\"command\")"]},{"anchor":"Extension","level":3,"type":"heading","text":"Extension"},{"type":"paragraph","inlineContent":[{"type":"text","text":"PLCommand is easier to scale."}]},{"type":"codeListing","syntax":"swift","code":["extension CommandValues {","    var swift: Alias {","        Alias(executableURL: \"\/usr\/bin\/swift\")","    }","}","","@Command(\\.swift) var swiftCommand"]},{"anchor":"License","level":2,"type":"heading","text":"License"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"plcommand"}]},{"type":"text","text":" is under MIT license. See the "},{"type":"reference","isActive":true,"identifier":"LICENSE"},{"type":"text","text":" file for more info."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/command\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/Command\/documentation\/Command\/GettingStarted","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Learn how to quickly execute commands on Swift using PLCommand."}],"kind":"article","metadata":{"roleHeading":"Article","title":"Getting started","role":"article","modules":[{"name":"Command"}]},"hierarchy":{"paths":[["doc:\/\/Command\/documentation\/Command"]]},"references":{"doc://Command/documentation/Command":{"role":"collection","title":"Command","abstract":[{"type":"text","text":"PLCommand is a library for Running Command from Swift"}],"identifier":"doc:\/\/Command\/documentation\/Command","kind":"symbol","type":"topic","url":"\/documentation\/command"},"LICENSE":{"title":"LICENSE","titleInlineContent":[{"type":"text","text":"LICENSE"}],"type":"link","identifier":"LICENSE","url":"LICENSE"}}}