{"abstract":[{"type":"text","text":"Learn how to quickly execute commands on Swift using PLCommand."}],"metadata":{"modules":[{"name":"Command"}],"title":"Getting started","roleHeading":"Article","role":"article"},"sections":[],"identifier":{"url":"doc:\/\/Command\/documentation\/Command\/GettingStarted","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/Command\/documentation\/Command"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Installation","text":"Installation"},{"inlineContent":[{"text":"PLCommand was deployed as Swift Package Manager. Package to install in a project. Add as a dependent item within the swift manifest.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let package = Package(","    ...","    dependencies: [","        .package(url: \"https:\/\/github.com\/pelagornis\/plcommand.git\", from: \"1.2.1\")","    ],","    ...",")"]},{"inlineContent":[{"type":"text","text":"Then import the PLCommand from thr location you want to use."}],"type":"paragraph"},{"syntax":"swift","code":["import Command"],"type":"codeListing"},{"level":2,"type":"heading","text":"Using PLCommand","anchor":"Using-PLCommand"},{"inlineContent":[{"type":"text","text":"PLCommand offers the most commonly used "},{"type":"codeVoice","code":"bash"},{"type":"text","text":" and "},{"code":"zsh","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"make"},{"type":"text","text":", which in addition helps users scale easily."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to use Bash."}]},{"code":["@Command(\\.bash) var bashCommand","bashCommand.run(\"command\")"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Or if you want to use zsh.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@Command(\\.zsh) var zshCommand","zshCommand.run(\"command\")"]},{"type"